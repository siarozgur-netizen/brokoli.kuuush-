<Window x:Class="OverlayTutorial.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="PlayLayer"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#000000"
        Opacity="1.0"
        PreviewKeyDown="OnWindowPreviewKeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="SearchRowDefinition" Height="36" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="StateBorder"
                BorderBrush="#00000000"
                BorderThickness="1"
                CornerRadius="6"
                Margin="1"
                Visibility="Collapsed"
                IsHitTestVisible="False"
                Panel.ZIndex="900" />

        <Border x:Name="SearchBarContainer"
                Grid.Row="0"
                Margin="8,6,8,2"
                Background="#111111"
                BorderBrush="#2B2B2B"
                BorderThickness="1"
                CornerRadius="4">
            <Grid>
                <TextBox x:Name="SearchTextBox"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="White"
                         CaretBrush="White"
                         FontSize="13"
                         Padding="10,6"
                         VerticalContentAlignment="Center"
                         KeyDown="OnSearchTextBoxKeyDown"
                         TextChanged="OnSearchTextBoxTextChanged"
                         GotFocus="OnSearchTextBoxGotFocus"
                         LostFocus="OnSearchTextBoxLostFocus" />
                <TextBlock x:Name="SearchPlaceholderTextBlock"
                           Text="Search YouTube…"
                           Foreground="#7D7D7D"
                           FontSize="13"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False" />
                <ProgressBar x:Name="NavigationProgressBar"
                             Height="2"
                             VerticalAlignment="Top"
                             Margin="4,1,4,0"
                             IsIndeterminate="True"
                             Visibility="Collapsed"
                             Foreground="#66C7FF"
                             Background="#00000000"
                             IsHitTestVisible="False" />
            </Grid>
        </Border>

        <wv2:WebView2 x:Name="OverlayWebView"
                      Grid.Row="1"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch" />

        <TextBlock x:Name="ModeIndicatorTextBlock"
                   Text="PASS 100%"
                   Foreground="White"
                   FontSize="12"
                   Margin="0,8,12,0"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Visibility="Collapsed"
                   IsHitTestVisible="False"
                   Panel.ZIndex="1000" />

        <Border x:Name="ActionOsdPanel"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="190"
                MaxWidth="260"
                Background="#D9101010"
                BorderBrush="#55FFFFFF"
                BorderThickness="1"
                CornerRadius="10"
                Padding="10,8"
                Visibility="Collapsed"
                Opacity="0"
                IsHitTestVisible="False"
                Panel.ZIndex="1030"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform x:Name="ActionOsdScaleTransform" ScaleX="0.96" ScaleY="0.96" />
            </Border.RenderTransform>
            <StackPanel>
                <Rectangle x:Name="ActionOsdAccentBar"
                           Height="2"
                           RadiusX="1"
                           RadiusY="1"
                           Fill="#6ACDFF"
                           Margin="0,0,0,7" />
                <TextBlock x:Name="ActionOsdTitleTextBlock"
                           Text="ACTION"
                           Foreground="#F5FFFFFF"
                           FontSize="12"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,1" />
                <TextBlock x:Name="ActionOsdDetailTextBlock"
                           Text="+10s"
                           Foreground="#CFFFFFFF"
                           FontSize="11"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <Border x:Name="HotkeyOverlayPanel"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="340"
                MaxWidth="340"
                Background="#B0121212"
                BorderBrush="#55FFFFFF"
                BorderThickness="1"
                CornerRadius="12"
                Padding="14,12"
                Visibility="Collapsed"
                IsHitTestVisible="False"
                Panel.ZIndex="1100">
            <StackPanel>
                <TextBlock Text="Overlay Controls"
                           Foreground="#F5FFFFFF"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <TextBlock Text="C  Help panel"
                           Foreground="#E6FFFFFF"
                           FontSize="12"
                           Margin="0,0,0,2" />
                <TextBlock Text="O  Show / Hide overlay"
                           Foreground="#E6FFFFFF"
                           FontSize="12"
                           Margin="0,0,0,2" />
                <TextBlock Text="I  Interact toggle"
                           Foreground="#E6FFFFFF"
                           FontSize="12"
                           Margin="0,0,0,2" />
                <TextBlock Text="S  Search mode toggle"
                           Foreground="#E6FFFFFF"
                           FontSize="12"
                           Margin="0,0,0,2" />
                <TextBlock Text="H  Open Home mode (larger)"
                           Foreground="#E6FFFFFF"
                           FontSize="12"
                           Margin="0,0,0,2" />
                <TextBlock Text="T  Force theater mode"
                           Foreground="#E6FFFFFF"
                           FontSize="12"
                           Margin="0,0,0,2" />
                <TextBlock Text="P  Play / Pause"
                           Foreground="#E6FFFFFF"
                           FontSize="12"
                           Margin="0,0,0,2" />
                <TextBlock Text="K/L or ,/.  Seek -/+10s"
                           Foreground="#E6FFFFFF"
                           FontSize="12"
                           Margin="0,0,0,2" />
                <TextBlock Text="Up / Down  Volume"
                           Foreground="#E6FFFFFF"
                           FontSize="12"
                           Margin="0,0,0,2" />
                <TextBlock Text="Left / Right  Prev / Next"
                           Foreground="#E6FFFFFF"
                           FontSize="12"
                           Margin="0,0,0,2" />
                <TextBlock Text="M  Mute toggle"
                           Foreground="#E6FFFFFF"
                           FontSize="12"
                           Margin="0,0,0,2" />
                <TextBlock Text="Q  Quit"
                           Foreground="#E6FFFFFF"
                           FontSize="12" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
