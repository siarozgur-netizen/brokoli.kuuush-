<Window x:Class="OverlayTutorial.StartupGuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PlayLayer Guide"
        Width="420"
        Height="260"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        ShowActivated="False"
        Focusable="False">
    <Border CornerRadius="14"
            BorderBrush="#66FFFFFF"
            BorderThickness="1"
            Background="#B314171C"
            Padding="16,14">
        <StackPanel>
            <TextBlock Text="PlayLayer Controls"
                       Foreground="#F5FFFFFF"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10" />

            <TextBlock Text="Quick Keys"
                       Foreground="#CFEFFF"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6" />
            <TextBlock Text="All shortcuts use Ctrl + Alt"
                       Foreground="#BFD8EA"
                       FontSize="11"
                       Margin="0,0,0,8" />

            <WrapPanel Margin="0,0,0,10">
                <Border Background="#2A4D63"
                        BorderBrush="#66D9FF"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8,4"
                        Margin="0,0,6,6">
                    <TextBlock Text="Ctrl + Alt + C  Guide"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="SemiBold" />
                </Border>
                <Border Background="#2A4D63"
                        BorderBrush="#66D9FF"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8,4"
                        Margin="0,0,6,6">
                    <TextBlock Text="Ctrl + Alt + H  Home"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="SemiBold" />
                </Border>
                <Border Background="#2A4D63"
                        BorderBrush="#66D9FF"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8,4"
                        Margin="0,0,6,6">
                    <TextBlock Text="Ctrl + Alt + S  Search"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="SemiBold" />
                </Border>
                <Border Background="#2A4D63"
                        BorderBrush="#66D9FF"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8,4"
                        Margin="0,0,6,6">
                    <TextBlock Text="Ctrl + Alt + O  Show/Hide"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="SemiBold" />
                </Border>
                <Border Background="#2A4D63"
                        BorderBrush="#66D9FF"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8,4"
                        Margin="0,0,6,6">
                    <TextBlock Text="Ctrl + Alt + P  Play/Pause"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="SemiBold" />
                </Border>
                <Border Background="#304B2A"
                        BorderBrush="#8AF090"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8,4"
                        Margin="0,0,6,6">
                    <TextBlock Text="Ctrl + Alt + K / L  -10s / +10s"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="SemiBold" />
                </Border>
            </WrapPanel>

            <TextBlock Text="Other Keys"
                       Foreground="#C9D4DF"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4" />
            <TextBlock Text="I Interact • T Theater • M Mute"
                       Foreground="#DCE5EE"
                       FontSize="11"
                       Margin="0,0,0,2" />
            <TextBlock Text=",/. Seek fallback ±10s • Up/Down Volume"
                       Foreground="#DCE5EE"
                       FontSize="11"
                       Margin="0,0,0,2" />
            <TextBlock Text="Left/Right Prev/Next • Q Quit"
                       Foreground="#DCE5EE"
                       FontSize="11"
                       Margin="0,0,0,2" />
            <TextBlock Text="Auto closes in 5 seconds"
                       Foreground="#B8FFFFFF"
                       FontSize="11"
                        Margin="0,3,0,0" />
        </StackPanel>
    </Border>
</Window>
