<Window x:Class="OverlayTutorial.StartupGuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PlayLayer Guide"
        Width="420"
        Height="260"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        ShowActivated="False"
        Focusable="False">
    <Border CornerRadius="14"
            BorderBrush="#66FFFFFF"
            BorderThickness="1"
            Background="#B314171C"
            Padding="16,14">
        <StackPanel>
            <TextBlock Text="PlayLayer Controls"
                       Foreground="#F5FFFFFF"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10" />
            <TextBlock Text="O Show/Hide • I Interact • S Search/Theater • H Home • T Force Theater"
                       Foreground="#E6FFFFFF"
                       FontSize="12"
                       Margin="0,0,0,4" />
            <TextBlock Text="P Play/Pause • K/L or ,/. Seek ±10s • M Mute"
                       Foreground="#E6FFFFFF"
                       FontSize="12"
                       Margin="0,0,0,4" />
            <TextBlock Text="Up/Down Volume • Left/Right Prev/Next • Q Quit"
                       Foreground="#E6FFFFFF"
                       FontSize="12"
                       Margin="0,0,0,4" />
            <TextBlock Text="C Toggle this guide in overlay"
                       Foreground="#D4FFFFFF"
                       FontSize="11"
                       Margin="0,10,0,0" />
            <TextBlock Text="Auto closes in 5 seconds"
                       Foreground="#B8FFFFFF"
                       FontSize="11"
                       Margin="0,3,0,0" />
        </StackPanel>
    </Border>
</Window>
